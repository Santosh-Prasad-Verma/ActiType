{
  "manifest_version": 3,
  "name": "ActiType",
  "version": "3.0.0",
  "description": "Smart paste that bypasses detection + keeps window always active to prevent test interruptions.",
  "background": {
    "service_worker": "src/background/worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/inject/anti-anti-debug.js",
        "data/inject/copyOverride.js",
        "data/inject/customPaste.js",
        "data/inject/mock_code.js",
        "data/inject/ss-stealth.js",
        "data/inject/main.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "permissions": [
    "management",
    "tabs",
    "activeTab",
    "contextMenus",
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "scripting",
    "windows",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "key": "",
  "externally_connectable": {
    "matches": [
      "http://*/*",
      "https://*/*"
    ]
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "images/ActiType.png",
      "48": "images/ActiType.png",
      "128": "images/ActiType.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "data/inject/copyOverride.js",
        "data/inject/customPaste.js",
        "data/inject/rightclickmenu.js",
        "data/inject/isolated.js",
        "data/inject/content.js",
        "src/content/contentScript.js"
      ],
      "exclude_matches": [
        "*://*.discord.com/*",
        "*://*.figma.com/*"
      ]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "js": [
        "src/devtools/devtools.js"
      ]
    },
    {
      "js": [
        "data/inject/anti-anti-debug.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "matchOriginAsFallback": true,
      "world": "MAIN",
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "js": [
        "data/inject/ss-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "matchOriginAsFallback": true,
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "js": [
        "data/inject/ss-stealth.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "matchOriginAsFallback": true,
      "world": "MAIN",
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "js": ["data/inject/main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "matchOriginAsFallback": true,
      "world": "MAIN",
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": ["*://*.discord.com/*", "*://*.figma.com/*"]
    }
  ],
  "commands": {
    "triggerSmartPaste": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Smart Paste"
    },
    "toggleHUD": {
      "suggested_key": {
        "default": "Alt+O",
        "mac": "Alt+O"
      },
      "description": "Toggle HUD Visibility"
    },
    "customPaste": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "mac": "Alt+Shift+V"
      },
      "description": "Paste Menu"
    },
    "forceCopy": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Alt+C"
      },
      "description": "Force Copy (Smart Copy)"
    }
  },
  "icons": {
    "16": "images/ActiType.png",
    "48": "images/ActiType.png",
    "128": "images/ActiType.png"
  }
}